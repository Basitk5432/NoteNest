<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <supports-screens
        android:anyDensity="true"
        android:largeScreens="true"
        android:normalScreens="true"
        android:smallScreens="true"
        android:xlargeScreens="true" />

    <application
        android:name=".NotesApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_neww"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_neww_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NotesApp">

        <activity
            android:name=".presentation.ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.NotesApp.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".presentation.ui.archive.ArchiveActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NotesApp"/>

        <activity
            android:name=".presentation.ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NotesApp" />
        <activity
            android:name=".presentation.ui.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.main.MainActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.notes.NotesActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.notes.AddEditNoteActivity"
            android:exported="false" />

        <meta-data
            android:name="android.max_aspect"
            android:value="2.4" />

    </application>
</manifest>
